<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fjdialect.mapper.AudioMapper">

    <resultMap id="AudioResultMap" type="com.fjdialect.entity.Audio">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="cityCode" column="city_code"/>
        <result property="dialectType" column="dialect_type"/>
        <result property="description" column="description"/>
        <result property="audioUrl" column="audio_url"/>
        <result property="uploader" column="uploader"/>
        <result property="uploaderId" column="uploader_id"/>
        <result property="rating" column="rating"/>
        <result property="status" column="status"/>
        <result property="rejectReason" column="reject_reason"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 获取已审核通过的音频列表 -->
    <select id="getApprovedAudioList" resultMap="AudioResultMap">
        SELECT * FROM audio 
        WHERE status = 'approved' 
        ORDER BY create_time DESC
    </select>

    <!-- 获取待审核的音频列表 -->
    <select id="getPendingAudioList" resultMap="AudioResultMap">
        SELECT * FROM audio 
        WHERE status = 'pending' 
        ORDER BY create_time DESC
    </select>

    <!-- 获取用户的音频列表 -->
    <select id="getUserAudioList" parameterType="java.lang.Long" resultMap="AudioResultMap">
        SELECT * FROM audio 
        WHERE uploader_id = #{uploaderId}
        ORDER BY create_time DESC
    </select>

</mapper>
